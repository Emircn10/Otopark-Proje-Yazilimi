@page "{id:int}"
@model OtoparkSistemi.Pages.Vehicles.EditModel
@{ ViewData["Title"] = "Araç Düzenle"; }

<div class="page-header">
    <h2>✏️ Araç Düzenle</h2>
    <a href="/Vehicles" class="btn btn-secondary">← Geri</a>
</div>

<div class="card" style="max-width:560px;">
    <div class="card-header">Araç Bilgileri – @Model.Arac.Plaka</div>
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="Arac.AracId" />
            <input type="hidden" asp-for="Arac.OlusturmaTarihi" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="form-group">
                <label class="form-label" asp-for="Arac.Plaka">Plaka *</label>
                <input asp-for="Arac.Plaka" class="form-control plaka-input" />
                <span asp-validation-for="Arac.Plaka" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="Arac.AracTipi">Araç Tipi *</label>
                <select asp-for="Arac.AracTipi" class="form-select">
                    <option>Otomobil</option><option>Motosiklet</option><option>Kamyonet</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="Arac.SahibiAdi">Sahibi Adı</label>
                <input asp-for="Arac.SahibiAdi" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="Arac.SahibiTelefon">Telefon</label>
                <input asp-for="Arac.SahibiTelefon" class="form-control" />
            </div>
            <div style="display:flex;gap:10px;">
                <button type="submit" class="btn btn-primary">💾 Güncelle</button>
                <a href="/Vehicles" class="btn btn-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
